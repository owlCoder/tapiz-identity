{
  "name": "@tapizlabs/identity",
  "version": "0.1.1",
  "type": "module",
  "private": false,
  "description": "Zero-dependency identity & SSO-projection rules shared across Tapiz products (LMS + spokes).",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sso": {
      "types": "./dist/sso.d.ts",
      "import": "./dist/sso.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "node scripts/clean.mjs",
    "dev:watch": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "prepack": "npm run build",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "publish:public": "npm publish --access public"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  },
  "license": "MIT",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "tapiz",
    "identity",
    "sso",
    "entitlements"
  ]
}
